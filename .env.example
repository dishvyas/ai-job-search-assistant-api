APP_NAME=AI Job Search Assistant API
ENVIRONMENT=local
DEBUG=true

# LLM provider: "mock" (default), "gemini", or "openai"
LLM_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Database URL. SQLite is the default for local dev. Switch to PostgreSQL for production.
# PostgreSQL example: postgresql+psycopg://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///./local.db

# Workflow mode: "single_step" (default) or "agentic"
# single_step: one LLM call generates all output (fast, cheap)
# agentic:     four-stage LangGraph workflow with intermediate reasoning (richer, more calls)
WORKFLOW_MODE=single_step

# RAG pipeline settings
# RAG is disabled by default. Set to true to enable semantic retrieval.
# Requires PostgreSQL with pgvector extension and a valid OPENAI_API_KEY.
RAG_ENABLED=false
ARTIFACT_RETRIEVAL_ENABLED=false
ARTIFACT_RETRIEVAL_TOP_K=3
ARTIFACT_SIMILARITY_THRESHOLD=0.70
# OpenAI generation + embeddings
# Used for generation when LLM_PROVIDER=openai.
# Also used for embeddings when RAG_ENABLED=true.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.75

APP_NAME=AI Job Search Assistant API
ENVIRONMENT=local
DEBUG=true

LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ai_job_search

WORKFLOW_MODE=agentic

RAG_ENABLED=false
ARTIFACT_RETRIEVAL_ENABLED=false
ARTIFACT_RETRIEVAL_TOP_K=3
ARTIFACT_SIMILARITY_THRESHOLD=0.70
EMBEDDING_MODEL=text-embedding-3-small
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.75
